# ── Staleks ERP — Production Environment Example ──────────────────────────────
# Copy this file to .env.prod and fill in the real values.
# Generate secrets with:  openssl rand -hex 32

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=staleks_erp
POSTGRES_USER=staleks
POSTGRES_PASSWORD=<CHANGE_ME>

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<CHANGE_ME>

# ── Backend / JWT ─────────────────────────────────────────────────────────────
SECRET_KEY=<CHANGE_ME_run_openssl_rand_hex_32>
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Domain / URLs ─────────────────────────────────────────────────────────────
DOMAIN=erp.yourdomain.com
ALLOWED_ORIGINS=https://erp.yourdomain.com
NEXT_PUBLIC_API_URL=https://erp.yourdomain.com/api/v1
NEXT_PUBLIC_APP_NAME=Staleks ERP
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── Phase 2 (not used yet) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
BITRIX24_WEBHOOK_URL=
BITRIX24_API_KEY=
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=staleks-erp
